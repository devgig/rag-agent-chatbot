# OPTIONAL: Only deploy this if you enable authentication in Milvus
# To use:
# 1. Enable authentication in your Milvus Helm chart values
# 2. Create Milvus user and password
# 3. Store credentials in Azure Key Vault
# 4. Rename this file to remove .optional extension
# 5. Add to kustomization.yaml resources
# 6. Update backend code to use credentials (see MILVUS_SETUP.md)

apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: milvus-external-secret
  annotations:
    "external-secrets.io/delete-on-resource-deletion": "true"
spec:
  refreshInterval: "0"
  secretStoreRef:
    name: azure-keyvault-secret-store
    kind: ClusterSecretStore
  target:
    name: milvus-credentials
    creationPolicy: Owner
    template:
      mergePolicy: Merge
      # These values are hardcoded in the template
      # Adjust based on your Milvus configuration
      data:
        # Option 1: Username/Password authentication
        username: "multi_agent_user"

        # Option 2: Token authentication (uncomment if using token instead)
        # token: "{{ .token | toString }}"
  data:
    # Fetch password from Azure Key Vault
    - secretKey: password
      remoteRef:
        key: multi-agent-milvus-password

    # If using token authentication, uncomment this:
    # - secretKey: token
    #   remoteRef:
    #     key: multi-agent-milvus-token
